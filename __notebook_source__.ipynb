


# =========================================================
# IMPORT + SETUP
# =========================================================

import os
import random
import torch
import torch.nn as nn
import torch.optim as optim

from torchvision import transforms
from torchvision.datasets import ImageFolder
from torch.utils.data import DataLoader, Subset

import timm

from sklearn.model_selection import StratifiedKFold
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, classification_report, confusion_matrix

import matplotlib.pyplot as plt
import seaborn as sns

from tqdm.auto import tqdm
import numpy as np

# ======================
# SEED (REPRODUCIBILITY)
# ======================
seed = 42
torch.manual_seed(seed)
np.random.seed(seed)
random.seed(seed)

if torch.cuda.is_available():
    torch.cuda.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

# ======================
# DEVICE
# ======================
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Menggunakan device: {device}")





# =========================================================
# DATA PREPARATION (CROSS-VALIDATION READY)
# =========================================================

# ======================
# TRANSFORM
# ======================

train_transform = transforms.Compose([
    transforms.RandomResizedCrop(224),
    transforms.RandomHorizontalFlip(0.5),
    transforms.RandomVerticalFlip(0.2),
    transforms.RandomRotation(30),
    transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.1, hue=0.05),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406],
                         [0.229, 0.224, 0.225])
])

val_test_transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406],
                         [0.229, 0.224, 0.225])
])

# ======================
# PATH
# ======================

train_dir = '/kaggle/input/datasets/rm1000/grape-disease-dataset-original/Original Data/train'
test_dir  = '/kaggle/input/datasets/rm1000/grape-disease-dataset-original/Original Data/test'

# ======================
# LOAD DATASET
# ======================

full_dataset = ImageFolder(root=train_dir)  # TANPA transform
test_dataset = ImageFolder(root=test_dir, transform=val_test_transform)

classes = full_dataset.classes
targets = np.array(full_dataset.targets)

print("="*40)
print("✅ DATASET BERHASIL DI-LOAD")
print(f"Total Kelas: {len(classes)}")
print(f"Daftar Kelas: {classes}")
print(f"Total Train Data: {len(full_dataset)}")
print(f"Total Test Data : {len(test_dataset)}")
print("="*40)

# ======================
# STRATIFIED K-FOLD
# ======================

k_folds = 5
skf = StratifiedKFold(n_splits=k_folds, shuffle=True, random_state=42)

print(f"\n✅ Stratified {k_folds}-Fold siap digunakan")





# =========================================================
# CROSS-VALIDATION TRAINING (FIXED)
# =========================================================

import os
# Fix 1: HuggingFace token
# from kaggle_secrets import UserSecretsClient
# os.environ["HF_TOKEN"] = UserSecretsClient().get_secret("HF_TOKEN")

fold_results = []
for fold, (train_idx, val_idx) in enumerate(skf.split(np.zeros(len(targets)), targets)):
    print(f"\n========== FOLD {fold+1}/{k_folds} ==========")

    train_dataset = ImageFolder(train_dir, transform=train_transform)
    val_dataset   = ImageFolder(train_dir, transform=val_test_transform)
    train_subset  = Subset(train_dataset, train_idx)
    val_subset    = Subset(val_dataset, val_idx)

    # ── Fix 2: num_workers=0 prevents multiprocessing cleanup crash in Kaggle
    train_loader = DataLoader(
        train_subset, batch_size=32, shuffle=True,
        num_workers=0,          # <── changed from 2
        pin_memory=True
    )
    val_loader = DataLoader(
        val_subset, batch_size=32, shuffle=False,
        num_workers=0,          # <── changed from 2
        pin_memory=True
    )

    model     = timm.create_model('mobilevit_s', pretrained=True, num_classes=len(classes)).to(device)
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.AdamW(model.parameters(), lr=1e-4, weight_decay=1e-2)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=30, eta_min=1e-6)

    best_val_acc       = 0.0
    patience_counter   = 0
    early_stop_patience = 5

    for epoch in range(30):
        # ── TRAIN
        model.train()
        correct_train, total_train, running_loss = 0, 0, 0.0
        for images, labels in tqdm(train_loader, desc=f"Fold {fold+1} Epoch {epoch+1} [Train]"):
            images, labels = images.to(device), labels.to(device)
            optimizer.zero_grad()
            outputs = model(images)
            loss    = criterion(outputs, labels)
            loss.backward()
            optimizer.step()
            running_loss  += loss.item() * images.size(0)
            _, preds       = torch.max(outputs, 1)
            correct_train += (preds == labels).sum()
            total_train   += labels.size(0)

        epoch_train_acc = (correct_train.double() / total_train).item()

        # ── VALIDATION
        model.eval()
        correct_val, total_val, val_loss = 0, 0, 0.0
        with torch.no_grad():
            for images, labels in tqdm(val_loader, desc=f"Fold {fold+1} Epoch {epoch+1} [Val]"):
                images, labels = images.to(device), labels.to(device)
                outputs  = model(images)
                loss     = criterion(outputs, labels)
                val_loss += loss.item() * images.size(0)
                _, preds  = torch.max(outputs, 1)
                correct_val += (preds == labels).sum()
                total_val   += labels.size(0)

        epoch_val_acc = (correct_val.double() / total_val).item()
        scheduler.step()
        print(f"Epoch {epoch+1:02d} | Train Acc: {epoch_train_acc:.4f} | Val Acc: {epoch_val_acc:.4f}")

        if epoch_val_acc > best_val_acc:
            best_val_acc     = epoch_val_acc
            torch.save(model.state_dict(), f'best_mobilevit_fold{fold+1}.pth')
            patience_counter = 0
        else:
            patience_counter += 1
            if patience_counter >= early_stop_patience:
                print(f"Early stopping at epoch {epoch+1}")
                break

    print(f"Fold {fold+1} BEST ACC: {best_val_acc:.4f}")
    fold_results.append(best_val_acc)

    # ── Fix 3: explicitly release loaders to prevent stale worker references
    del train_loader, val_loader, train_subset, val_subset
    del train_dataset, val_dataset, model, optimizer, scheduler
    torch.cuda.empty_cache()

print("\n========== CV SUMMARY ==========")
print("Fold Results :", fold_results)
print("Mean Accuracy:", np.mean(fold_results))
print("Std           :", np.std(fold_results))





# =========================================================
# FINAL EVALUATION (ENSEMBLE K-FOLD)
# =========================================================

# ======================
# 1. LOAD SEMUA MODEL
# ======================
models = []

num_folds = 5  # sesuaikan jika fold berubah

for fold in range(1, num_folds + 1):
    model = timm.create_model('mobilevit_s', pretrained=False, num_classes=len(classes))
    model.load_state_dict(torch.load(f'best_mobilevit_fold{fold}.pth'))
    model = model.to(device)
    model.eval()
    
    models.append(model)

print(f"\n{len(models)} models loaded for ensemble")

# ======================
# 2. DATALOADER TEST
# ======================
test_loader = DataLoader(test_dataset, batch_size=32, shuffle=False, num_workers=2)

# ======================
# 3. ENSEMBLE INFERENCE
# ======================
all_preds = []
all_labels = []

with torch.no_grad():
    test_loop = tqdm(test_loader, desc="Ensemble Evaluation [Test Set]")
    
    for images, labels in test_loop:
        images = images.to(device)

        outputs_sum = None

        # Loop semua model
        for model in models:
            outputs = model(images)
            probs = torch.softmax(outputs, dim=1)

            if outputs_sum is None:
                outputs_sum = probs
            else:
                outputs_sum += probs

        # Average probabilitas
        outputs_avg = outputs_sum / len(models)

        preds = torch.argmax(outputs_avg, dim=1)

        all_preds.extend(preds.cpu().numpy())
        all_labels.extend(labels.numpy())

# ======================
# 4. METRICS
# ======================
accuracy = accuracy_score(all_labels, all_preds)
precision = precision_score(all_labels, all_preds, average='weighted', zero_division=0)
recall = recall_score(all_labels, all_preds, average='weighted', zero_division=0)
f1 = f1_score(all_labels, all_preds, average='weighted', zero_division=0)

print("\n========== ENSEMBLE TEST RESULT ==========")
print(f"Accuracy : {accuracy:.4f}")
print(f"Precision: {precision:.4f}")
print(f"Recall   : {recall:.4f}")
print(f"F1-Score : {f1:.4f}")

# ======================
# 5. CLASSIFICATION REPORT
# ======================
print("\nClassification Report:")
print(classification_report(all_labels, all_preds, target_names=classes, zero_division=0))

# ======================
# 6. CONFUSION MATRIX
# ======================
cm = confusion_matrix(all_labels, all_preds)

plt.figure(figsize=(10, 8))
sns.heatmap(cm,
            annot=True,
            fmt='d',
            cmap='Blues',
            xticklabels=classes,
            yticklabels=classes)

plt.xlabel('Predicted Label')
plt.ylabel('True Label')
plt.title('Confusion Matrix - Ensemble')
plt.show()





# =========================================================
# VISUALIZATION
# =========================================================

# ======================
# 1. CROSS-VALIDATION LINE PLOT
# ======================
plt.figure(figsize=(8,5))

plt.plot(range(1, len(fold_results)+1), fold_results, marker='o')
plt.title('Cross-Validation Accuracy per Fold')
plt.xlabel('Fold')
plt.ylabel('Accuracy')
plt.ylim(0.9, 1.01)
plt.grid(True)

# tampilkan nilai di atas titik
for i, acc in enumerate(fold_results):
    plt.text(i+1, acc, f"{acc:.4f}", ha='center', va='bottom')

plt.show()


# ======================
# 2. BOXPLOT (STABILITY CHECK)
# ======================
plt.figure(figsize=(6,5))

plt.boxplot(fold_results, vert=True)
plt.title('Cross-Validation Accuracy Distribution')
plt.ylabel('Accuracy')

plt.grid(True)
plt.show()


# ======================
# 3. CONFUSION MATRIX (RAW)
# ======================
cm = confusion_matrix(all_labels, all_preds)

plt.figure(figsize=(10,8))
sns.heatmap(cm,
            annot=True,
            fmt='d',
            cmap='Blues',
            xticklabels=classes,
            yticklabels=classes,
            linewidths=0.5,
            linecolor='black')

plt.xlabel('Predicted Label')
plt.ylabel('True Label')
plt.title('Confusion Matrix - Test Set')

plt.tight_layout()
plt.show()


# ======================
# 4. CONFUSION MATRIX (NORMALIZED)
# ======================
cm_norm = cm.astype('float') / cm.sum(axis=1)[:, np.newaxis]

plt.figure(figsize=(10,8))
sns.heatmap(cm_norm,
            annot=True,
            fmt='.2f',
            cmap='Blues',
            xticklabels=classes,
            yticklabels=classes)

plt.xlabel('Predicted Label')
plt.ylabel('True Label')
plt.title('Normalized Confusion Matrix')

plt.tight_layout()
plt.show()


# =========================================================
# GRAD-CAM IMPROVED — Sharper, Multi-layer, Full Diagnostics
# =========================================================
get_ipython().getoutput("pip install -q grad-cam")

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import torch
import torch.nn.functional as F
import timm
from torchvision.datasets import ImageFolder
from torchvision import transforms
from pytorch_grad_cam import (
    GradCAM, GradCAMPlusPlus, EigenCAM, LayerCAM
)
from pytorch_grad_cam.utils.image import show_cam_on_image
from pytorch_grad_cam.utils.model_targets import ClassifierOutputTarget

# =========================================================
# CONFIG
# =========================================================
test_dir    = '/kaggle/input/datasets/rm1000/grape-disease-dataset-original/Original Data/test'
MODEL_PATH  = 'best_mobilevit_fold1.pth'
N_SAMPLES   = 4          # correct + wrong each → total 8 rows
CAM_METHOD  = 'gradcam++'  # 'gradcam' | 'gradcam++' | 'eigencam' | 'layercam'
ALPHA       = 0.5          # heatmap blend strength (lower = subtler overlay)
COLORMAP    = 'jet'        # 'jet' | 'turbo' | 'plasma'

# =========================================================
# TRANSFORM
# =========================================================
val_test_transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406],
                         [0.229, 0.224, 0.225])
])

# =========================================================
# DATASET
# =========================================================
test_dataset = ImageFolder(test_dir, transform=val_test_transform)
classes      = test_dataset.classes
print(f"Classes: {classes}")

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Device : {device}")

# =========================================================
# MODEL
# =========================================================
model = timm.create_model('mobilevit_s', pretrained=False, num_classes=len(classes))
model.load_state_dict(torch.load(MODEL_PATH, map_location=device))
model = model.to(device)
model.eval()

# =========================================================
# TARGET LAYER SELECTION
# ─────────────────────────────────────────────────────────
# KEY FIX for "big red blob":
#   • Use an EARLIER or MIDDLE stage for higher spatial resolution
#   • GradCAM++ further sharpens attribution vs plain GradCAM
#   • We expose all candidate layers so you can compare easily
# =========================================================
target_layer_map = {
    'last'   : model.stages[-1],           # original — coarse, low-res
    'second' : model.stages[-2],           # one step earlier — better detail
    'third'  : model.stages[-3],           # even earlier — highest spatial res
}

# ── pick your layer here ──
ACTIVE_LAYER = 'last'   # <── try 'third' if still too blobby
target_layers = [target_layer_map[ACTIVE_LAYER]]
print(f"Using target layer: stages[{ACTIVE_LAYER}]")

# =========================================================
# CAM METHOD FACTORY
# =========================================================
cam_registry = {
    'gradcam'   : GradCAM,
    'gradcam++' : GradCAMPlusPlus,   # sharper, less blobby
    'eigencam'  : EigenCAM,           # no gradients, smooth
    'layercam'  : LayerCAM,           # most fine-grained
}
cam = cam_registry[CAM_METHOD](model=model, target_layers=target_layers)
print(f"CAM method: {CAM_METHOD}")

# =========================================================
# HELPERS
# =========================================================
mean = np.array([0.485, 0.456, 0.406])
std  = np.array([0.229, 0.224, 0.225])

def denorm(tensor_img):
    img = tensor_img.numpy().transpose(1, 2, 0)
    img = img * std + mean
    return np.clip(img, 0, 1)

def get_prediction(input_tensor):
    with torch.no_grad():
        logits = model(input_tensor)
        probs  = F.softmax(logits, dim=1)[0]
    pred_idx  = probs.argmax().item()
    pred_conf = probs[pred_idx].item()
    return pred_idx, pred_conf, probs.cpu().numpy()

def run_cam(input_tensor, target_class):
    return cam(input_tensor=input_tensor,
               targets=[ClassifierOutputTarget(target_class)])[0]

# =========================================================
# COLLECT CORRECT / WRONG SAMPLES
# =========================================================
correct_samples, wrong_samples = [], []
all_indices = np.random.permutation(len(test_dataset))

print("Scanning for correct/wrong predictions...")
for idx in all_indices:
    if len(correct_samples) >= N_SAMPLES and len(wrong_samples) >= N_SAMPLES:
        break
    image, label = test_dataset[idx]
    input_tensor = image.unsqueeze(0).to(device)
    pred_idx, pred_conf, probs = get_prediction(input_tensor)

    entry = dict(image=image, label=label, pred=pred_idx, conf=pred_conf, probs=probs)
    if pred_idx == label and len(correct_samples) < N_SAMPLES:
        correct_samples.append(entry)
    elif pred_idx != label and len(wrong_samples) < N_SAMPLES:
        wrong_samples.append(entry)

print(f"Collected {len(correct_samples)} correct, {len(wrong_samples)} wrong samples")

# =========================================================
# PLOT — Correct (top) | Wrong (bottom)
# Each row: Original | Heatmap | Overlay | Top-3 bar chart
# =========================================================
COLS       = 4   # original / heatmap / overlay / bar
all_groups = [('✅ Correct', correct_samples, 'green'),
              ('❌ Wrong',   wrong_samples,   'red')]

total_rows = sum(len(g[1]) for g in all_groups)
fig, axes  = plt.subplots(total_rows, COLS, figsize=(18, total_rows * 3.5))
if total_rows == 1:
    axes = axes[np.newaxis, :]

fig.suptitle(
    f'Grad-CAM Analysis  |  Method: {CAM_METHOD.upper()}  |  Layer: stages[{ACTIVE_LAYER}]',
    fontsize=14, fontweight='bold', y=1.01
)

row_idx = 0
for group_label, samples, border_color in all_groups:
    for s_i, entry in enumerate(samples):
        image      = entry['image']
        label      = entry['label']
        pred       = entry['pred']
        conf       = entry['conf']
        probs      = entry['probs']

        input_tensor = image.unsqueeze(0).to(device)
        img_np       = denorm(image)

        # ── CAM for predicted class (what the model attended to)
        cam_map_pred = run_cam(input_tensor, pred)

        # ── CAM for true class (what it SHOULD attend to, only for wrong)
        if pred != label:
            cam_map_true = run_cam(input_tensor, label)
        else:
            cam_map_true = None

        overlay_pred = show_cam_on_image(img_np, cam_map_pred,
                                         use_rgb=True, image_weight=1 - ALPHA)

        ax_orig    = axes[row_idx, 0]
        ax_heat    = axes[row_idx, 1]
        ax_overlay = axes[row_idx, 2]
        ax_bar     = axes[row_idx, 3]

        # ── Col 0: Original image with border
        ax_orig.imshow(img_np)
        ax_orig.set_title(
            f'{group_label} [{s_i+1}/{len(samples)}]\n'
            f'GT: {classes[label]}',
            fontsize=8, color=border_color, fontweight='bold'
        )
        for spine in ax_orig.spines.values():
            spine.set_edgecolor(border_color)
            spine.set_linewidth(3)

        # ── Col 1: Raw heatmap
        ax_heat.imshow(cam_map_pred, cmap=COLORMAP, vmin=0, vmax=1)
        ax_heat.set_title(f'Heatmap (pred: {classes[pred]})', fontsize=8)

        # ── Col 2: Overlay — if wrong, show true-class CAM too
        if cam_map_true is not None:
            overlay_true = show_cam_on_image(img_np, cam_map_true,
                                              use_rgb=True, image_weight=1 - ALPHA)
            # side-by-side within the cell using a split image
            combined = np.concatenate([overlay_pred, overlay_true], axis=1)
            ax_overlay.imshow(combined)
            ax_overlay.set_title(
                f'Pred ← | → GT\n(conf: {conf:.1%})',
                fontsize=8, color='darkorange'
            )
        else:
            ax_overlay.imshow(overlay_pred)
            ax_overlay.set_title(f'Overlay  (conf: {conf:.1%})', fontsize=8)

        # ── Col 3: Top-3 confidence bar chart
        top3_idx  = np.argsort(probs)[::-1][:3]
        top3_conf = probs[top3_idx]
        top3_lbl  = [classes[i] for i in top3_idx]
        bar_colors = ['#2ecc71' if i == label else
                      '#e74c3c' if i == pred  else
                      '#95a5a6' for i in top3_idx]
        bars = ax_bar.barh(range(3), top3_conf[::-1], color=bar_colors[::-1])
        ax_bar.set_yticks(range(3))
        ax_bar.set_yticklabels(top3_lbl[::-1], fontsize=7)
        ax_bar.set_xlim(0, 1)
        ax_bar.set_xlabel('Confidence', fontsize=7)
        ax_bar.set_title('Top-3 Predictions', fontsize=8)
        for bar, val in zip(bars, top3_conf[::-1]):
            ax_bar.text(min(val + 0.02, 0.95), bar.get_y() + bar.get_height()/2,
                        f'{val:.1%}', va='center', fontsize=7)

        # ── hide axes ticks for image panels
        for ax in [ax_orig, ax_heat, ax_overlay]:
            ax.axis('off')

        row_idx += 1

# ── legend
legend_patches = [
    mpatches.Patch(color='#2ecc71', label='Ground Truth class'),
    mpatches.Patch(color='#e74c3c', label='Predicted class (wrong)'),
    mpatches.Patch(color='#95a5a6', label='Other class'),
]
fig.legend(handles=legend_patches, loc='lower center',
           ncol=3, fontsize=9, bbox_to_anchor=(0.5, -0.01))

plt.tight_layout()
plt.savefig('gradcam_improved.png', dpi=150, bbox_inches='tight')
plt.show()
print("Saved → gradcam_improved.png")
